rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "ytgabgal@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    // Rules for "users" collection and nested sub-collections
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /likedTracks/{trackId} {
        allow read, write: if isOwner(userId);
      }

      match /playlists/{playlistId} {
        allow read, write: if isOwner(userId);
      }

      match /history/{historyId} {
        allow read, write: if isOwner(userId);
      }

      match /followedArtists/{artistId} {
        allow read, write: if isOwner(userId);
      }

      match /searchHistory/{searchId} {
        allow read, write: if isOwner(userId);
      }

      match /personalizedPlaylists/{playlistId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Rules for "mot_de_passe" collection
    match /mot_de_passe/{userId} {
      allow read, write: if isOwner(userId);
      allow read: if isAdmin();
    }

    // Rules for "sharedPlaylists" collection
    match /sharedPlaylists/{playlistId} {
      allow read: if true;
      allow create, update: if playlistId is string && playlistId.size() <= 128 &&
                              request.resource.data.name is string && 
                              request.resource.data.name.size() <= 100 &&
                              request.resource.data.tracks is list && 
                              request.resource.data.tracks.size() <= 300;
    }
  }
}
